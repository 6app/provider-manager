def list_providers() -> int:
    store = load_store()
    providers = store.get("providers") or []
    if not providers:
        print("没有保存的提供商。运行 cx 进入管理界面添加。")
        return 1
    active_id = detected_active_provider_id(store)
    for i, p in enumerate(providers, 1):
        active = " *" if p.get("id") == active_id else ""
        print(f"{i}. {p.get('name') or p.get('id')} [{p.get('wire_api') or 'responses'}]{active}")
        print(f"   id={p.get('id')} base_url={p.get('base_url')} model={p.get('default_model') or '-'} key={redact(p.get('api_key') or '')}")
    return 0


def provider_by_num(num: str) -> Dict[str, Any]:
    store = load_store()
    providers = store.get("providers") or []
    try:
        idx = int(str(num), 10) - 1
    except Exception:
        raise CXError("--provider 必须是数字，从 1 开始")
    if idx < 0 or idx >= len(providers):
        raise CXError(f"provider 序号不存在: {num}（当前共有 {len(providers)} 个）")
    return providers[idx]


def launch_codex(settings: Dict[str, Any], passthrough: Sequence[str]) -> int:
    codex = shutil.which("codex")
    if not codex:
        raise CXError("找不到 codex 命令，请先安装 Codex CLI")
    passthrough = list(passthrough)
    if passthrough[:1] == ["--"]:
        passthrough = passthrough[1:]
    settings = get_settings({"settings": settings})
    env = proxy_env(proxy_enabled=settings["proxy_enabled"], proxy_url=settings["proxy_url"])
    proxy_msg = f"代理 {settings['proxy_url']}" if settings["proxy_enabled"] else "禁用代理"
    print(f"启动 codex（{proxy_msg}）…", file=sys.stderr)
    os.execvpe(codex, ["codex", *passthrough], env)
    return 0


def noninteractive_switch(provider_num: Optional[str], start_codex: bool, passthrough: Sequence[str]) -> int:
    store_for_settings = load_store()
    settings = get_settings(store_for_settings)
    if provider_num is None:
        if start_codex:
            # In a TTY, let user select; otherwise fail with a clear message.
            if sys.stdin.isatty() and sys.stdout.isatty():
                store = store_for_settings
                selected_holder: Dict[str, Any] = {}

                def _pick(stdscr: Any) -> int:
                    chosen = choose_provider(stdscr, store, "选择启动 Codex 使用的提供商")
                    if not chosen:
                        return 1
                    selected_holder["provider"] = chosen[1]
                    return 0
                code = curses.wrapper(_pick)
                if code:
                    return code
                p = selected_holder["provider"]
            else:
                raise CXError("--start-codex 非交互模式需要 --provider N")
        else:
            return main_ui()
    else:
        p = provider_by_num(provider_num)

    switch_provider(p)
    print(f"已切换到 provider: {p.get('name') or p.get('id')}（仅更新 OPENAI_API_KEY 和 base_url）", file=sys.stderr)
    if start_codex:
        return launch_codex(settings=settings, passthrough=passthrough)
    return 0


def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="cx",
        description="Codex 接入点 / provider 管理工具",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    p.add_argument("--start-codex", action="store_true", help="切换后直接启动 codex")
    p.add_argument("--provider", metavar="N", help="选择第 N 个 provider（从 cx --list 查看）")
    p.add_argument("--enable-proxy", metavar="BOOL", type=parse_bool,
                   help="启用/禁用代理并保存到设置：true/false、1/0、yes/no、on/off")
    p.add_argument("--list", action="store_true", help="列出已保存 provider")
    p.add_argument("--version", action="version", version="cx 1.1")
    return p


def main(argv: Optional[Sequence[str]] = None) -> int:
    parser = build_arg_parser()
    args, passthrough = parser.parse_known_args(argv)
    try:
        if any(x == "--no-proxy" or x.startswith("--no-proxy=") for x in passthrough):
            parser.error("--no-proxy 已删除，请改用 --enable-proxy true|false")
        if passthrough and not args.start_codex:
            parser.error("未知参数: " + " ".join(passthrough))
        if args.enable_proxy is not None:
            store = load_store()
            settings = update_settings(store, proxy_enabled=args.enable_proxy)
            print(f"代理设置已保存: {proxy_label(settings)}", file=sys.stderr)
            if not args.list and not args.provider and not args.start_codex:
                return 0
        if args.list:
            return list_providers()
        if args.provider or args.start_codex:
            return noninteractive_switch(args.provider, args.start_codex, passthrough)
        return main_ui()
    except KeyboardInterrupt:
        print("\n已取消", file=sys.stderr)
        return 130
    except CXError as e:
        print(f"cx: {e}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
